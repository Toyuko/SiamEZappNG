# Production API (default works on Android emulator with internet)
EXPO_PUBLIC_API_URL=https://siam-e-zweb-ng.vercel.app

# Pusher (job board real-time feed — same keys as SiamEZwebNG NEXT_PUBLIC_PUSHER_*)
EXPO_PUBLIC_PUSHER_KEY=
EXPO_PUBLIC_PUSHER_CLUSTER=

# Local Next.js backend from Android emulator (host machine localhost)
# EXPO_PUBLIC_API_URL=http://10.0.2.2:3000

# Force offline mock data (no network required)
# EXPO_PUBLIC_FREELANCER_MOCK=true
